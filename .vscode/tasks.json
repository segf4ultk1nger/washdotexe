{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build wash.exe for debugging",
            "command": "nim",
            "args": [
                "compile",
                "-g",
                "--debugger:native",
                "-o:${workspaceRoot}/build/washdebug.exe",
                "${relativeFile}"
            ],
            "options": {
                "cwd": "${workspaceRoot}"
            },
            "type": "shell",
        }
    ]
}